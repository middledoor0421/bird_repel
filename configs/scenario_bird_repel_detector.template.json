{
  "scenario": "scenario_a",
  "replay": {
    "manifest_path": "/path/to/replay_manifest.jsonl",
    "timestamp_tolerance_ms": 20,
    "output_dir": "artifacts/scenario_bird_repel_detector"
  },
  "cameras": [
    {
      "camera_id": "cam_wide",
      "role": "primary"
    },
    {
      "camera_id": "cam_tele",
      "role": "verification"
    }
  ],
  "detector": {
    "name": "bird_repel_detector",
    "params": {
      "model_target": "../bird_repel/central/detector/model.py:BirdDetector",
      "model_init_params": {
        "weights": "/path/to/yolo_weights.pt",
        "device": "cuda:0",
        "input_size": 640,
        "conf_th": 0.25,
        "iou_th": 0.5,
        "only_bird": true
      },
      "input_mode": "numpy_bgr",
      "class_name": "bird",
      "min_confidence": 0.25
    }
  },
  "verifier": {
    "name": "heuristic_verifier",
    "params": {
      "score_threshold": 0.7,
      "min_quality": 0.3
    }
  },
  "tracker": {
    "name": "simple_tracker",
    "params": {
      "confirm_after": 2,
      "max_missing_seconds": 0.5
    }
  },
  "policy": {
    "verification_threshold": 0.7,
    "review_threshold": 0.5,
    "quality_threshold": 0.3,
    "max_candidates_per_tick": 3
  },
  "simulator": {
    "actuator_enabled": true,
    "actuator_failure_rate": 0.0
  },
  "extra": {
    "verification_deadline_ms": 250,
    "note": "Template for using the bird_repel BirdDetector as the stage1 detector."
  }
}
