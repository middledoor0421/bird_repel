{
  "scenario": "scenario_a",
  "replay": {
    "manifest_path": "/path/to/replay_bundle/replay_manifest.jsonl",
    "timestamp_tolerance_ms": 5,
    "output_dir": "artifacts/scenario_image_stat"
  },
  "cameras": [
    {
      "camera_id": "cam_wide",
      "role": "primary"
    },
    {
      "camera_id": "cam_wide",
      "role": "verification"
    }
  ],
  "detector": {
    "name": "mean_intensity_detector",
    "params": {
      "min_mean_intensity": 0.1,
      "bbox_width_ratio": 0.25,
      "bbox_height_ratio": 0.25,
      "class_name": "bird"
    }
  },
  "verifier": {
    "name": "crop_variance_verifier",
    "params": {
      "min_variance_score": 0.05
    }
  },
  "tracker": {
    "name": "simple_tracker",
    "params": {
      "confirm_after": 1,
      "max_missing_seconds": 1.0
    }
  },
  "policy": {
    "verification_threshold": 0.05,
    "review_threshold": 0.05,
    "quality_threshold": 0.0,
    "max_candidates_per_tick": 3
  },
  "simulator": {
    "actuator_enabled": true,
    "actuator_failure_rate": 0.0
  },
  "extra": {
    "verification_deadline_ms": 250,
    "note": "Simple image-backed baseline that proves image_ref loading works end-to-end."
  }
}
