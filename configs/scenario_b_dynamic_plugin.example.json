{
  "scenario": "scenario_b",
  "replay": {
    "manifest_path": "examples/replay_manifest.jsonl",
    "timestamp_tolerance_ms": 20,
    "output_dir": "artifacts/scenario_b_dynamic_plugin"
  },
  "cameras": [
    {
      "camera_id": "cam_wide",
      "role": "wide"
    },
    {
      "camera_id": "cam_tele",
      "role": "zoom"
    }
  ],
  "detector": {
    "name": "./examples/custom_plugins.py:ExternalMetadataDetector",
    "params": {
      "min_confidence": 0.4
    }
  },
  "verifier": {
    "name": "heuristic_verifier",
    "params": {
      "score_threshold": 0.7,
      "min_quality": 0.3
    }
  },
  "tracker": {
    "name": "simple_tracker",
    "params": {
      "confirm_after": 1,
      "max_missing_seconds": 0.5
    }
  },
  "trigger_policy": {
    "name": "./examples/custom_plugins.py:ExternalReviewBandTriggerPolicy",
    "params": {
      "min_confidence": 0.45,
      "max_confidence": 0.85
    }
  },
  "candidate_selector": {
    "name": "./examples/custom_plugins.py:ExternalTopOneSelector",
    "params": {}
  },
  "policy": {
    "verification_threshold": 0.7,
    "review_threshold": 0.5,
    "quality_threshold": 0.3,
    "max_candidates_per_tick": 1
  },
  "simulator": {
    "actuator_enabled": true,
    "actuator_failure_rate": 0.0
  },
  "extra": {
    "verification_deadline_ms": 250,
    "note": "Runnable example for dynamic plugins on scenario B, including candidate selection."
  }
}
