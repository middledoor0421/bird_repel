{
  "scenario": "scenario_a",
  "replay": {
    "manifest_path": "examples/replay_manifest.jsonl",
    "timestamp_tolerance_ms": 20,
    "output_dir": "artifacts/scenario_bird_sahi_detector"
  },
  "cameras": [
    {
      "camera_id": "cam_wide",
      "role": "primary"
    },
    {
      "camera_id": "cam_tele",
      "role": "verification"
    }
  ],
  "detector": {
    "name": "bird_sahi_temporal_yolo_detector",
    "params": {
      "model_target": "./examples/repo_bridge_demo_models.py:BirdSahiLikeYoloDetector",
      "model_init_params": {
        "min_confidence": 0.45,
        "target_class_name": "target"
      },
      "input_mode": "frame_packet",
      "class_name_map": {
        "0": "bird",
        "1": "non_bird"
      },
      "default_class_name": "bird",
      "min_confidence": 0.45
    }
  },
  "verifier": {
    "name": "heuristic_verifier",
    "params": {
      "score_threshold": 0.7,
      "min_quality": 0.3
    }
  },
  "tracker": {
    "name": "simple_tracker",
    "params": {
      "confirm_after": 2,
      "max_missing_seconds": 0.5
    }
  },
  "policy": {
    "verification_threshold": 0.7,
    "review_threshold": 0.5,
    "quality_threshold": 0.3,
    "max_candidates_per_tick": 3
  },
  "simulator": {
    "actuator_enabled": true,
    "actuator_failure_rate": 0.0
  },
  "extra": {
    "verification_deadline_ms": 250,
    "note": "Runnable smoke config for the bird_sahi_temporal YOLO wrapper using a demo model with the same predict() contract."
  }
}
