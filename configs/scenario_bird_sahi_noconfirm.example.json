{
  "scenario": "scenario_a",
  "replay": {
    "manifest_path": "examples/replay_manifest.jsonl",
    "timestamp_tolerance_ms": 20,
    "output_dir": "artifacts/scenario_bird_sahi_noconfirm"
  },
  "cameras": [
    {
      "camera_id": "cam_wide",
      "role": "primary"
    },
    {
      "camera_id": "cam_tele",
      "role": "verification"
    }
  ],
  "detector": {
    "name": "manifest_detector",
    "params": {
      "min_confidence": 0.4
    }
  },
  "verifier": {
    "name": "bird_sahi_temporal_local_verifier",
    "params": {
      "model_target": "./examples/repo_bridge_demo_models.py:BirdSahiLikeYoloDetector",
      "model_init_params": {
        "min_confidence": 0.45,
        "target_class_name": "target"
      },
      "input_mode": "roi_array",
      "class_name_map": {
        "0": "target",
        "1": "distractor"
      },
      "target_labels": [
        "target"
      ],
      "score_threshold": 0.74,
      "min_quality": 0.3
    }
  },
  "tracker": {
    "name": "simple_tracker",
    "params": {
      "confirm_after": 2,
      "max_missing_seconds": 0.5
    }
  },
  "trigger_policy": {
    "name": "confidence_band_trigger_policy",
    "params": {
      "low": 0.45,
      "high": 0.8
    }
  },
  "verification_scheduler": {
    "name": "bird_sahi_always_verify_scheduler",
    "params": {
      "require_trigger": true,
      "require_selection": true,
      "require_target_frame": true
    }
  },
  "confirmation_policy": {
    "name": "noop_confirmation_policy",
    "params": {}
  },
  "environment": {
    "name": "bird_sahi_noconfirm_partial_mock",
    "target_labels": [
      "target"
    ],
    "non_target_labels": [
      "distractor"
    ],
    "latency_budget_ms": 120.0,
    "metadata": {
      "method_role": "verifier_policy_bundle",
      "note": "Partial thesis3-side approximation of the bird-sahi no-confirm operating point."
    }
  },
  "policy": {
    "verification_threshold": 0.7,
    "review_threshold": 0.5,
    "quality_threshold": 0.3,
    "max_candidates_per_tick": 3
  },
  "simulator": {
    "actuator_enabled": true,
    "actuator_failure_rate": 0.0
  },
  "extra": {
    "verification_deadline_ms": 250,
    "experiment_group": "bird_sahi_noconfirm_partial"
  }
}
