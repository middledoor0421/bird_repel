{
  "scenario": "scenario_a",
  "replay": {
    "manifest_path": "examples/replay_manifest.jsonl",
    "timestamp_tolerance_ms": 20,
    "output_dir": "artifacts/scenario_detector_only_baseline"
  },
  "cameras": [
    {
      "camera_id": "cam_wide",
      "role": "primary"
    },
    {
      "camera_id": "cam_tele",
      "role": "verification"
    }
  ],
  "detector": {
    "name": "manifest_detector",
    "params": {
      "min_confidence": 0.4
    }
  },
  "tracker": {
    "name": "simple_tracker",
    "params": {
      "confirm_after": 2,
      "max_missing_seconds": 0.5
    }
  },
  "environment": {
    "name": "detector_only_baseline",
    "target_labels": [
      "target"
    ],
    "non_target_labels": [
      "distractor"
    ],
    "latency_budget_ms": 40.0,
    "metadata": {
      "purpose": "fixed comparison baseline without stage2 verification"
    }
  },
  "policy": {
    "verification_threshold": 0.7,
    "review_threshold": 0.5,
    "quality_threshold": 0.3,
    "max_candidates_per_tick": 3
  },
  "simulator": {
    "actuator_enabled": true,
    "actuator_failure_rate": 0.0
  },
  "extra": {
    "experiment_group": "baseline_detector_only",
    "note": "Keep this as a stable comparison group while intermediate methods change."
  }
}
