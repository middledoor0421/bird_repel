{
  "scenario": "scenario_a",
  "replay": {
    "manifest_path": "examples/replay_manifest.jsonl",
    "timestamp_tolerance_ms": 20,
    "output_dir": "artifacts/scenario_methodology_hooks"
  },
  "cameras": [
    {
      "camera_id": "cam_wide",
      "role": "primary"
    },
    {
      "camera_id": "cam_tele",
      "role": "verification"
    }
  ],
  "detector": {
    "name": "manifest_detector",
    "params": {
      "min_confidence": 0.4
    }
  },
  "verifier": {
    "name": "heuristic_verifier",
    "params": {
      "score_threshold": 0.7,
      "min_quality": 0.3
    }
  },
  "tracker": {
    "name": "simple_tracker",
    "params": {
      "confirm_after": 2,
      "max_missing_seconds": 0.5
    }
  },
  "verification_scheduler": {
    "name": "examples/custom_plugins.py:ExternalConfidenceBandScheduler",
    "params": {
      "min_confidence": 0.5,
      "max_confidence": 0.8,
      "require_target_frame": true,
      "require_target_label": true
    }
  },
  "confirmation_policy": {
    "name": "examples/custom_plugins.py:ExternalEnvironmentConfirmationPolicy",
    "params": {
      "min_verifier_score": 0.74,
      "min_track_confidence": 0.5,
      "require_target_label": true
    }
  },
  "environment": {
    "name": "real_data_adaptation_mock",
    "target_labels": [
      "target"
    ],
    "non_target_labels": [
      "distractor"
    ],
    "safe_zone": {
      "mode": "mock"
    },
    "latency_budget_ms": 120.0,
    "review_budget_per_minute": 12.0,
    "metadata": {
      "site": "simulated_cctv_site_a",
      "goal": "swap scheduling and confirmation methods without changing the pipeline skeleton"
    }
  },
  "policy": {
    "verification_threshold": 0.7,
    "review_threshold": 0.5,
    "quality_threshold": 0.3,
    "max_candidates_per_tick": 3
  },
  "simulator": {
    "actuator_enabled": true,
    "actuator_failure_rate": 0.0
  },
  "extra": {
    "verification_deadline_ms": 250,
    "experiment_group": "methodology_hook_demo",
    "note": "This run keeps the baseline detector fixed but swaps intermediate methodology hooks."
  }
}
